# Telegram bot token (from @BotFather)
BOT_TOKEN=your-telegram-bot-token

# Telegram Bot API URL — default is https://api.telegram.org
# Set to http://localhost:8081 if using a local Bot API server with MTProto proxy
# TELEGRAM_API_URL=https://api.telegram.org

# LLM configuration
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
# LLM API key — either paste the key directly or reference an env var: ${OPENAI_API_KEY}
LLM_API_KEY=${OPENAI_API_KEY}
LLM_USE_REASONING=true
LLM_REASONING_EFFORT=high
# Optional: temperature for the primary agent model (default: 0.6)
# LLM_TEMPERATURE=0.6
# Optional: temperature for the utility summarization model (default: 0.2)
# LLM_UTILITY_TEMPERATURE=0.2
# Optional: cheaper model for summarization/compaction (defaults to LLM_MODEL)
# LLM_UTILITY_MODEL=gpt-4o-mini

# Allowed Telegram user IDs (empty = open access)
# Supported formats: JSON array [123, 456]
ALLOWED_USERS=[]

# Path to SQLite database file
DATABASE_PATH=data/sessions.db
